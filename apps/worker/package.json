{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate:local": "wrangler d1 migrations apply designsystem-healthcheck-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply designsystem-healthcheck-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "~0.5.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "vitest": "~2.1.0",
    "wrangler": "^4"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
